[Unit]
Description=RelaySMS Gateway Server FTP Server
PartOf=relaysms-gateway-server.target
After=network.target

[Service]
WorkingDirectory=/opt/relaysms/relaysms-gateway-server
EnvironmentFile=/opt/relaysms/relaysms-gateway-server/.env
ExecStart=/opt/relaysms/relaysms-gateway-server/venv/bin/python3 -u -m src.ftp_server
SyslogIdentifier=relaysms-gateway-server-ftp
ReadWritePaths=/opt/relaysms/relaysms-gateway-server/data

[Install]
WantedBy=relaysms-gateway-server.target
